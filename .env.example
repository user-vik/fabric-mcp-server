# Copy to `.env` for local debugging, or set inside the MCP client's `env` block.

# ─── Authentication ──────────────────────────────────────────────────────────
# interactive       (default) Opens a browser; for desktop devs (AVD works).
# device-code       Prints a code + URL to stderr; for SSH/WSL/headless.
# cli               Uses your existing `az login` session.
# service-principal Non-interactive, uses CLIENT_ID + CLIENT_SECRET below.
# managed-identity  For servers hosted on Azure.
# default           Tries env -> managed-identity -> CLI -> browser in turn.
FABRIC_AUTH_MODE=interactive

# Entra tenant ID. Required for interactive / device-code / service-principal.
AZURE_TENANT_ID=<your-entra-tenant-id>

# App (client) ID. Optional for interactive/device-code (defaults to Azure CLI
# public client). Required for service-principal.
AZURE_CLIENT_ID=

# Client secret. Required ONLY for service-principal.
AZURE_CLIENT_SECRET=

# ─── Server mode ─────────────────────────────────────────────────────────────
# read (default) — discovery, run-history, refresh-history, git-status, and
#                  execute_dax (read-only DAX) tools.
# write          — also exposes run_pipeline, cancel_pipeline_run,
#                  refresh_dataset, and update_from_git.
# Note: execute_dax needs Build permission on the target semantic model and the
# tenant's "Dataset Execute Queries REST API" admin setting enabled.
FABRIC_MCP_MODE=read
